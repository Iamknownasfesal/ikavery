# Dynamic Labs project env id. The value below is the one provisioned for
# `solana.ikavery.com`; rotate via the Dynamic dashboard if the project
# moves. Falls back to this default at build time so first-clone dev works
# without any setup.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=9dd6152b-680a-4322-bee8-69fced543f9a

# Solana RPC. Devnet by default for the pre-alpha demo.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Ikavery program id on devnet — keep in sync with `solana/programs/ikavery/src/lib.rs`.
NEXT_PUBLIC_IKAVERY_PROGRAM_ID=6kdyWi8FJah4xt2SyL2fEBFYacQ7iaDsgQjKCDhgEbCi

# ika dWallet pre-alpha gRPC endpoint.
NEXT_PUBLIC_IKA_GRPC=pre-alpha-dev-1.ika.ika-network.net:443
