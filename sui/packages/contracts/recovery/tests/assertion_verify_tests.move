/// Happy-path + failure-mode tests for the WebAuthn credential path through
/// `auth::verify`. The vectors below were generated by
/// `sui/packages/sdk/scripts/gen-webauthn-fixture.ts` — re-run that script
/// and paste the output here if you need to refresh them.
#[test_only]
module recovery::assertion_verify_tests;

use recovery::assertion;
